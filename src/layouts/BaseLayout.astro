---
// BaseLayout.astro
// Root layout with head metadata, fonts, background layers, and navigation.
import Background from "../components/Background.astro";
import CursorGlow from "../components/CursorGlow.astro";
import NavBar from "../components/NavBar.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Ian Lucero | Ingenieria Electronica</title>
    <meta
      name="description"
      content="Electronica desde los componentes. IoT, Embedded Systems y PCB Design."
    />

    <!-- Open Graph -->
    <meta property="og:title" content="Ian Lucero | Ingenieria Electronica" />
    <meta
      property="og:description"
      content="Electronica desde los componentes. IoT, Embedded Systems y PCB Design."
    />
    <meta property="og:type" content="website" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon: geometric lightning bolt -->
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><path fill='%23C9A84C' d='M18 2L6 18h8l-2 12 12-16h-8l4-12z'/></svg>"
    />
  </head>

  <body class="bg-night text-parchment font-sans overflow-x-hidden antialiased">
    <!-- Ambient background layers -->
    <Background />
    <CursorGlow />

    <!-- Navigation (load immediately) -->
    <NavBar />

    <!-- Page content -->
    <main>
      <slot />
    </main>
  </body>
</html>
