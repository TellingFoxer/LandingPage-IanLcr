---
// Certifications.astro
// Infinite horizontal carousel with centered active card, auto-play, arrows.
import { certifications } from "../data/certifications";
---

<section id="certifications" class="relative z-10 py-24 px-6 max-w-5xl mx-auto">
  <h2
    class="reveal font-serif text-4xl sm:text-5xl font-bold text-gold glow-text text-center mb-16"
  >
    Certificaciones
  </h2>

  <div class="carousel-container reveal relative select-none">
    <!-- Prev arrow -->
    <button
      class="carousel-arrow carousel-prev absolute top-1/2 -left-3 sm:-left-5 -translate-y-1/2 z-20 w-10 h-10 rounded-full glass-strong flex items-center justify-center text-parchment/70 hover:text-gold transition-all duration-300 cursor-pointer hover:scale-110"
      aria-label="Anterior"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M11 14L6 9L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Viewport -->
    <div class="carousel-viewport overflow-hidden rounded-2xl">
      <div class="carousel-track flex gap-4">
        {certifications.map((cert) => (
          <a
            href={cert.url || "#"}
            target={cert.url ? "_blank" : "_self"}
            rel={cert.url ? "noopener noreferrer" : undefined}
            class="cert-card shrink-0 w-[280px] sm:w-[320px] glass rounded-2xl p-6 flex flex-col justify-between border border-parchment/5 hover:border-gold/20 transition-all duration-500 group cursor-pointer no-underline"
          >
            <!-- Top: issuer logo + date -->
            <div>
              <div class="flex items-start justify-between mb-4">
                <span
                  class="w-10 h-10 rounded-xl flex items-center justify-center text-sm font-bold"
                  style="background: rgba(201, 168, 76, 0.1); color: #C9A84C"
                >
                  {cert.logo}
                </span>
                <span class="text-[11px] text-gray-tech/60 font-mono tracking-wider">
                  {cert.date}
                </span>
              </div>

              <!-- Title -->
              <h3
                class="font-serif text-lg font-semibold text-parchment/90 leading-snug mb-1 group-hover:text-gold transition-colors duration-300"
              >
                {cert.title}
              </h3>

              <!-- Issuer -->
              <p class="text-xs text-gold/70 font-medium tracking-wide mb-3">
                {cert.issuer}
              </p>

              <!-- Description -->
              <p class="text-xs text-parchment/60 leading-relaxed">
                {cert.description}
              </p>
            </div>

            <!-- External indicator -->
            {cert.url && (
              <span class="mt-4 inline-flex items-center gap-1 text-[11px] text-gray-tech/40 group-hover:text-aero-cyan transition-colors duration-300 tracking-wide uppercase">
                Ver credencial
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="opacity-50">
                  <path d="M1 11L11 1M11 1H3.5M11 1V8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            )}
          </a>
        ))}
      </div>
    </div>

    <!-- Next arrow -->
    <button
      class="carousel-arrow carousel-next absolute top-1/2 -right-3 sm:-right-5 -translate-y-1/2 z-20 w-10 h-10 rounded-full glass-strong flex items-center justify-center text-parchment/70 hover:text-gold transition-all duration-300 cursor-pointer hover:scale-110"
      aria-label="Siguiente"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M7 14L12 9L7 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Dots -->
    <div class="carousel-dots flex justify-center gap-2 mt-6"></div>
  </div>
</section>

<script>
  const INTERVAL_MS = 4000;

  const viewport = document.querySelector<HTMLElement>(".carousel-viewport");
  const track = document.querySelector<HTMLElement>(".carousel-track");
  const prevBtn = document.querySelector<HTMLElement>(".carousel-prev");
  const nextBtn = document.querySelector<HTMLElement>(".carousel-next");
  const dotsContainer = document.querySelector<HTMLElement>(".carousel-dots");

  if (!viewport || !track || !prevBtn || !nextBtn || !dotsContainer) {
    throw new Error("Carousel elements not found");
  }

  const cards = Array.from(track.children) as HTMLElement[];
  const total = cards.length;
  let currentIndex = 0;
  let interval: ReturnType<typeof setInterval> | null = null;
  let isTransitioning = false;
  const gap = 16;

  // Clone first and last for seamless infinite loop
  const firstClone = cards[0].cloneNode(true) as HTMLElement;
  const lastClone = cards[total - 1].cloneNode(true) as HTMLElement;
  track.appendChild(firstClone);
  track.insertBefore(lastClone, cards[0]);

  const allSlides = Array.from(track.children) as HTMLElement[];
  const totalSlides = allSlides.length;

  // We start at the first real card (index 1, since index 0 is clone of last)
  let slideIndex = 1;
  // currentRealIndex = 0..total-1 for dots
  let currentRealIndex = 0;

  function getCardWidth(): number {
    return allSlides[0]?.offsetWidth ?? 320;
  }

  function getViewportWidth(): number {
    return viewport.offsetWidth;
  }

  function calcOffset(idx: number): number {
    const cardW = getCardWidth();
    const vpW = getViewportWidth();
    // Center the card in the viewport
    // offset = -(idx * (cardW + gap)) + (vpW - cardW) / 2
    return -(idx * (cardW + gap)) + (vpW - cardW) / 2;
  }

  function updateTrack(animate = true) {
    if (animate) {
      track.style.transition = "transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)";
    } else {
      track.style.transition = "none";
    }
    track.style.transform = `translateX(${calcOffset(slideIndex)}px)`;
  }

  // Force browser reflow (flush pending styles)
  function forceReflow() {
    track.offsetHeight; // triggers reflow
  }

  function handleTransitionEnd() {
    isTransitioning = false;

    // At the end — jumped into the clone of the first card
    if (slideIndex >= totalSlides - 1) {
      slideIndex = 1; // jump back to real first card
      updateTrack(false);
      forceReflow();
      return;
    }

    // At the beginning — jumped into the clone of the last card
    if (slideIndex <= 0) {
      slideIndex = total; // jump back to real last card
      updateTrack(false);
      forceReflow();
      return;
    }
  }

  function goTo(newSlideIdx: number) {
    if (isTransitioning) return;
    isTransitioning = true;

    slideIndex = newSlideIdx;
    currentRealIndex = ((slideIndex - 1) % total + total) % total;
    updateTrack(true);
    updateDots();
  }

  function next() {
    goTo(slideIndex + 1);
  }

  function prev() {
    goTo(slideIndex - 1);
  }

  function updateDots() {
    dotsContainer.querySelectorAll<HTMLElement>(".carousel-dot").forEach((dot, i) => {
      dot.classList.toggle("active", i === currentRealIndex);
    });
  }

  function startAuto() {
    stopAuto();
    interval = setInterval(next, INTERVAL_MS);
  }

  function stopAuto() {
    if (interval) {
      clearInterval(interval);
      interval = null;
    }
  }

  // Build dots
  for (let i = 0; i < total; i++) {
    const dot = document.createElement("button");
    dot.className =
      "carousel-dot w-2 h-2 rounded-full bg-parchment/20 transition-all duration-300 cursor-pointer hover:bg-gold/40";
    dot.setAttribute("aria-label", `Ir a certificacion ${i + 1}`);
    dot.dataset.index = String(i);
    dot.addEventListener("click", () => {
      stopAuto();
      goTo(i + 1); // +1 because real cards start at index 1
      startAuto();
    });
    dotsContainer.appendChild(dot);
  }

  // Listen for transition end for seamless wrap
  track.addEventListener("transitionend", handleTransitionEnd);

  // Initial position (first real card, no animation)
  slideIndex = 1;
  currentRealIndex = 0;
  updateTrack(false);
  forceReflow();
  updateDots();

  // Arrow events
  nextBtn.addEventListener("click", () => {
    stopAuto();
    next();
    startAuto();
  });

  prevBtn.addEventListener("click", () => {
    stopAuto();
    prev();
    startAuto();
  });

  // Keyboard
  document.addEventListener("keydown", (e) => {
    if (e.key === "ArrowRight") {
      stopAuto();
      next();
      startAuto();
    } else if (e.key === "ArrowLeft") {
      stopAuto();
      prev();
      startAuto();
    }
  });

  // Pause on hover
  const container = viewport.closest(".carousel-container");
  if (container) {
    container.addEventListener("mouseenter", stopAuto);
    container.addEventListener("mouseleave", startAuto);

    // Touch: pause while touching
    let touchMoved = false;
    container.addEventListener("touchstart", () => {
      stopAuto();
      touchMoved = false;
    });
    container.addEventListener("touchmove", () => {
      touchMoved = true;
    });
    container.addEventListener("touchend", () => {
      if (!touchMoved) {
        startAuto();
      } else {
        setTimeout(startAuto, 3000);
      }
    });
  }

  // Visibility
  document.addEventListener("visibilitychange", () => {
    if (document.hidden) {
      stopAuto();
    } else {
      startAuto();
    }
  });

  // Recalculate on resize
  let resizeTimer: number | undefined;
  window.addEventListener("resize", () => {
    if (resizeTimer) clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => {
      stopAuto();
      updateTrack(false);
      forceReflow();
      startAuto();
    }, 200);
  });

  // Start auto-play
  startAuto();
</script>
